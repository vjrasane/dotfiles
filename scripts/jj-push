#!/usr/bin/env bash
set -euo pipefail

# If we're not in a devenv shell but the repo has a devenv project, re-exec inside devenv
if [[ -z ${DEVENV_ROOT:-} ]]; then
	repo_root="$(jj root 2>/dev/null || true)"
	if [[ -n $repo_root && -d "$repo_root/.devenv" ]]; then
		echo "Re-executing in devenv shell..."
		exec devenv shell --devenv-root "$repo_root" -- "$0" "$@"
	fi
fi

run_hooks=true
args=()
for arg in "$@"; do
	if [[ $arg == "--no-hooks" ]]; then
		run_hooks=false
	else
		args+=("$arg")
	fi
done

if $run_hooks; then
	if command -v pre-commit &>/dev/null; then
		echo "Running pre-commit hooks..."
		if ! pre-commit run --all-files; then
			echo "Hooks failed, aborting push"
			exit 1
		fi
	elif command -v prek &>/dev/null && [[ -f .pre-commit-config.yaml ]]; then
		echo "Running prek hooks..."
		if ! prek run --all-files --config .pre-commit-config.yaml; then
			echo "Hooks failed, aborting push"
			exit 1
		fi
	fi
fi

echo "Running jj git push ${args[*]:-}"
exec jj git push "${args[@]}"
