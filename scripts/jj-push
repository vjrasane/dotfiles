#!/usr/bin/env bash
set -euo pipefail

run_hooks=true
args=()
for arg in "$@"; do
	if [[ "$arg" == "--no-hooks" ]]; then
		run_hooks=false
	else
		args+=("$arg")
	fi
done

if $run_hooks; then
	if command -v pre-commit &>/dev/null; then
		echo "Running pre-commit hooks..."
		if ! pre-commit run --all-files; then
			echo "Hooks failed, aborting push"
			exit 1
		fi
	elif command -v prek &>/dev/null && [[ -f .pre-commit-config.yaml ]]; then
		echo "Running prek hooks..."
		if ! prek run --all-files --config .pre-commit-config.yaml; then
			echo "Hooks failed, aborting push"
			exit 1
		fi
	elif command -v ripsecrets &>/dev/null; then
		echo "Running ripsecrets..."
		if ! ripsecrets --strict-ignore .; then
			echo "Secrets detected, aborting push"
			exit 1
		fi
	fi
fi

exec jj git push "${args[@]}"
